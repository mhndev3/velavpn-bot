# ─── Telegram ────────────────────────────────────────────────
BOT_TOKEN=

# Comma-separated numeric IDs of static head-admins
ADMIN_IDS=

# Developer-only: unlocks the /deathnote control panel
DEVELOPER_ID=

# Channel/group that receives new-order notifications
ADMIN_REPORT_CHANNEL_ID=
STARLINK_ADMIN_REPORT_CHANNEL_ID=

# ─── Pricing ─────────────────────────────────────────────────
STARLINK_PRICE_PER_GB=0
STARLINK_MAX_VOLUME_GB=0
USDT_TOMAN_RATE=0
TRX_TOMAN_RATE=0

# ─── Proxy (optional) ────────────────────────────────────────
USE_PROXY=false
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=1080
PROXY_USERNAME=
PROXY_PASSWORD=
