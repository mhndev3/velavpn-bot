# ─── GitHub Linguist: language stats ─────────────────────────
# Exclude dead/legacy code from the language breakdown
_deprecated/**   linguist-vendored

# Helper scripts shouldn't register as a language
run.bat          linguist-detectable=false

# Assets are not code
assets/**        linguist-vendored

# Docs shouldn't count toward code stats
*.md             linguist-documentation

# ─── Diff / merge behaviour ──────────────────────────────────
*.py             diff=python
*.md             diff=markdown
